<% layout("/layouts/boilerplate") %>
<body>
    <div class="row">
     <div class="col-8 offset-2">
      <h3> create new listing</h3>
      <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
          <div class="mb-3">
            <lable for="title" class="form-lable">Title</lable>
            <input  name="listing[title]" type="text" placeholder="Add a catchy title" class="form-control" required >
            <div class="valid-feedback">Tittle looks good!</div>
          </div>
         <div class="mb-3">
            <lable for="description" class="form-lable">Description</lable>
            <textarea  name="listing[description]" class="form-control" required></textarea>
            <div class="invalid-feedback">please enter short description</div>
         </div>
          <div class="mb-3">
            <lable for="image" class="form-lable">upload Image</lable>
            <input  name="listing[image]" type="file" placeholder="Enter Link/URL" class="form-control" required>
            <div class="invalid-feedback">Link should be valid</div>
         </div>
          <div class="row">
           <div class="mb-3 col-md-4">
            <lable for="price" class="form-lable">Price</lable>
            <input  name="listing[price]"  placeholder="1200" class="form-control" required >
            <div class="invalid-feedback">price should be valid</div>
           </div>
           <div class="mb-3 col-md-8">
            <lable for="country" class="form-lable">Country</lable>
            <input  name="listing[country]" type="text" placeholder="India" class="form-control" required>
            <div class="invalid-feedback">country should be valid</div>
           </div>
          </div>
         
         <div class="mb-3">
            <lable for="location" class="form-lable">Location</lable>
            <input  name="listing[location]" type="text" placeholder="jaipur,mumbai.." class="form-control" required>
            <div class="invalid-feedback">Location should be valid</div>
         </div>
         <button class="btn btn-dark add-btn">Add</button>
      </form>
     </div>
    </div>    
</body>
