<% layout("/layouts/boilerplate") %>
<body>
<div class="row">
   <div class="col-8 offset-2">
    <h3> Edit your listing here: </h3>
    <form method="post" action="/listings/<%= showList.id%>?_method=PUt" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
            <lable for="title" class="form-lable">Title</lable>
            <input name="listing[title]" type="text" class="form-control" value= "<%= showList.title %>" required> 
        </div>
        <div class="mb-3">
            <lable for="description" class="form-lable">Description</lable>
            <textarea name="listing[description]"class="form-control" required> "<%= showList.description %> "</textarea>
            <div class="invalid-feedback">please enter a short description</div>
        </div>
        <div class="mb-3">
            Original listing image <br>
            <img src="<%= originalImageUrl %>" />
        </div>
        <div class="mb-3">
            <lable for="image" class="form-lable">Upload new Image</lable>
            <input name="listing[image]" type="file" class="form-control">
            <div class="invalid-feedback">Link should be valid</div>
        </div>
        <div class="row">
           <div class="mb-3 col-md-4">
            <lable for="price" class="form-lable">Price</lable>
            <input name="listing[price]" type="number" placeholder="1200" value="<%= showList.price %>" class="form-control" required>
             <div class="invalid-feedback">price should be valid</div>   
        </div>
           <div class="mb-3 col-md-8">
            <lable for="country" class="form-lable">Country</lable>
            <input name="listing[country]" type="text" placeholder="India" value="<%= showList.country %>" class="form-control" required>
            <div class="invalid-feedback">country should be valid</div>
           </div>
        </div>
        <div class="mb-3">
            <lable for="location" class="form-lable">Location</lable>
            <input name="listing[location]" type="text" placeholder="jaipur,mumbai.." value="<%= showList.location %>" class="form-control" required>
             <div class="invalid-feedback">Location should be valid</div>
        </div>
         <button class="btn btn-dark edit-btn">Edit</button>
    </form>
  </div>
</div> 
</body>
